@page "/graph/polar"
@using SymBlazor.Graphing
@inject NavigationManager Navigation

<div class="page-shell graph-page-shell">
    <section class="hero content-hero graph-hero">
        <p class="eyebrow">Sym / Graphing</p>
        <h1>Polar Plot</h1>
        <p class="hero-copy">
            Plot a radial expression r = f(theta) in Plotly’s polar coordinate system. This is useful for rose curves,
            spirals, cardioids, and trigonometric symmetry patterns.
        </p>
        <div class="hero-actions">
            <a class="button-link primary" href="@GraphHomeHref">Graph Home</a>
            <a class="button-link secondary" href="/library/index.html">Library Home</a>
        </div>
    </section>

    <section class="section grid-two">
        <article class="panel prose">
            <span class="mini-label">Reading The Plot</span>
            <h2>Polar Curves Emphasize Symmetry</h2>
            <p>
                Polar plotting is especially useful when the mathematics is naturally radial. Rose curves, cardioids,
                spirals, and many trigonometric patterns are easier to recognize in polar coordinates than after being
                converted to rectangular form.
            </p>
            <p>
                It is often the clearest way to see repeated angular structure, petal counts, and rotational symmetries
                that would look less natural on an ordinary x-y graph.
            </p>
        </article>
        <article class="panel prose">
            <span class="mini-label">Practical Tip</span>
            <h2>Theta Is Sampled In Radians</h2>
            <p>
                Sym evaluates the expression using radians, then the page converts the sampled angles to degrees for
                Plotly’s polar renderer. That means trigonometric inputs should be written with the usual radian-based
                formulas such as <code>cos(theta)</code> or <code>sin(3 * theta)</code>.
            </p>
            <p>
                If a curve does not look like the form you expected, the first things to verify are the theta interval
                and the frequency inside the trigonometric expression.
            </p>
        </article>
    </section>

    <section class="section graph-workbench">
        <article class="panel graph-controls">
            <span class="mini-label">Inputs</span>
            <h2>Polar Settings</h2>

            <label class="graph-label">r(theta)
                <input class="graph-input" @bind="_expressionText" />
            </label>

            <div class="graph-inline-grid">
                <label class="graph-label">Angle Variable
                    <input class="graph-input" @bind="_angleName" />
                </label>
                <label class="graph-label">Samples
                    <input class="graph-input" type="number" min="50" max="1600" @bind="_samples" />
                </label>
            </div>

            <div class="graph-inline-grid">
                <label class="graph-label">Theta Min
                    <input class="graph-input" type="number" step="0.1" @bind="_thetaMin" />
                </label>
                <label class="graph-label">Theta Max
                    <input class="graph-input" type="number" step="0.1" @bind="_thetaMax" />
                </label>
            </div>

            <button class="button-link primary graph-button" @onclick="RenderGraph">Render Graph</button>

            <p class="graph-note">Example rose curve: <code>2 * cos(4 * theta)</code></p>
            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="graph-error">@_error</div>
            }
        </article>

        <article class="panel graph-output">
            <span class="mini-label">Plot</span>
            <h2>Large View</h2>
            <div class="graph-canvas-shell">
                <PlotlyChart Figure="@_figure" />
            </div>
        </article>
    </section>

    <div class="product-shell">
        <iframe class="product-frame" src="/ProductSection.html" title="ProductSection" loading="lazy"></iframe>
    </div>
    <footer class="site-footer">Copyright SymbolicComputation.com 2026. AI assisted.</footer>
</div>

@code {
    private string _expressionText = "2 * cos(4 * theta)";
    private string _angleName = "theta";
    private int _samples = 500;
    private double _thetaMin = 0d;
    private double _thetaMax = 6.283185307179586d;
    private string? _error;
    private Dictionary<string, object?> _figure = new();
    private string GraphHomeHref => $"{Navigation.BaseUri}graph";

    protected override void OnInitialized()
    {
        RenderGraph();
    }

    private void RenderGraph()
    {
        try
        {
            var sample = GraphMath.SamplePolar(_expressionText, _angleName, _thetaMin, _thetaMax, _samples);
            _figure = GraphFigures.PolarFigure($"r = {_expressionText}", sample.R, sample.Theta);
            _error = null;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
