@page "/rewrite-demo"

<div class="demo-page">
    <div class="demo-page-shell">
        <section class="demo-hero">
            <p class="demo-kicker">Sym Demo</p>
            <h1>Rewrite Demo</h1>
            <p class="demo-summary">
                This demo uses the real Sym backend to apply symbolic rewrite rules and show how equivalent expressions
                collapse into cleaner or more canonical forms under an explicit rule-pack strategy.
            </p>
            <p class="demo-summary">
                It is a compact way to inspect algebraic normalization, identity elimination, and custom rule behavior
                without leaving the browser or translating the problem into a separate test harness.
            </p>

            <div class="demo-notes">
                <div class="demo-note-card">
                    <h2>What This Demo Exercises</h2>
                    <p>
                        Sym explores equivalent forms by repeatedly applying rule matches over structured expressions,
                        then surfaces a simplified result that reflects the chosen algebraic or trigonometric strategy.
                    </p>
                </div>
                <div class="demo-note-card">
                    <h2>Technical Focus</h2>
                    <ul>
                        <li>Rule packs such as <code>Trigonometry</code> and <code>AlgebraicStrategy</code></li>
                        <li>Inline custom rules for one-off rewrite experiments</li>
                        <li>Exact symbolic equivalence rather than approximate numeric substitution</li>
                    </ul>
                </div>
            </div>
        </section>

        <SymDemoWorkbench Examples="@Examples" InitialInput="@Examples[0].Script" />
    </div>
</div>

@code {
    private static readonly IReadOnlyList<BlazorDemoExample> Examples = BlazorDemoCatalog.RewriteExamples;
}

<style>
    .demo-page {
        min-height: 100vh;
        padding: 1.5rem;
        color: #edf5ff;
        background:
            radial-gradient(circle at top left, rgba(74, 144, 226, 0.14), transparent 28rem),
            linear-gradient(180deg, #06111f 0%, #081a31 100%);
    }

    .demo-page-shell {
        width: min(1180px, 100%);
        margin: 0 auto;
    }

    .demo-hero {
        margin-bottom: 1.35rem;
    }

    .demo-kicker {
        margin: 0 0 0.4rem;
        color: #89d1b6;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .demo-page h1 {
        margin: 0;
        color: #edf5ff;
        font-family: "Palatino Linotype", "Book Antiqua", Georgia, serif;
    }

    .demo-page h1:focus,
    .demo-page h1:focus-visible {
        outline: none;
    }

    .demo-summary {
        max-width: 60rem;
        margin: 0.75rem 0 0;
        color: #edf5ff;
        line-height: 1.65;
    }

    .demo-notes {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.15rem;
    }

    .demo-note-card {
        padding: 1rem 1.1rem;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 0.95rem;
        background: rgba(6, 17, 31, 0.68);
        color: #edf5ff;
    }

    .demo-note-card h2 {
        margin: 0 0 0.55rem;
        font-size: 1rem;
        color: #edf5ff;
    }

    .demo-note-card p,
    .demo-note-card li {
        color: #edf5ff;
        line-height: 1.6;
    }

    .demo-note-card ul {
        margin: 0;
        padding-left: 1.2rem;
    }

    .demo-note-card code {
        color: #edf5ff;
        background: rgba(255, 255, 255, 0.08);
        padding: 0.1rem 0.3rem;
        border-radius: 0.35rem;
    }

    @@media (max-width: 900px) {
        .demo-page {
            padding: 1rem;
        }

        .demo-notes {
            grid-template-columns: 1fr;
        }
    }
</style>
