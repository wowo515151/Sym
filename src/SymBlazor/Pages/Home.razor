@page "/sym"
@page "/sym/"
@inject HttpClient Http
@using WordsToSym
@using System.Threading
@using System.Net.Http.Json
@using System.Text.RegularExpressions

<div class="main-container">
    <div class="page-header">
        <div>
            <p class="page-kicker">SymbolicComputation.com</p>
            <h1>Sym Online</h1>
            <p class="page-summary">
                The main Sym interface for running ProblemScript, algebraic simplification, calculus queries,
                equation-solving workflows, and tensor-oriented rewrites in the browser.
            </p>
        </div>
        <div class="header-links">
            <a class="btn btn-outline-light" href="/">Home</a>
            <a class="btn btn-outline-light" href="/library/">Library</a>
            <a class="btn btn-outline-light" href="/resume.html">ProductSection</a>
            <a class="btn btn-outline-light" href="/sym/rewrite-demo">Rewrite Demo</a>
            <a class="btn btn-outline-light" href="/sym/tensor-demo">Tensor Demo</a>
            <a class="btn btn-outline-light" href="/sym/derivative-demo">Derivative Demo</a>
        </div>
    </div>

    <div class="toolbar">
        <div class="toolbar-section">
            <button class="btn btn-primary" @onclick="StartSolving" disabled="@_isSolving">Start</button>
            <button class="btn btn-secondary" @onclick="StopSolving" disabled="@(!_isSolving)">Stop</button>
        </div>

        <fieldset class="group-box examples-group">
            <legend>Examples</legend>
            <select @onchange="OnExampleSelected" class="form-select">
                <option value="">-- Select an Example --</option>
                @foreach (var example in _examples)
                {
                    <option value="@example">@example</option>
                }
            </select>
        </fieldset>

        <div class="toolbar-section">
            <a class="btn btn-primary" href="/SymUIHelp.html" target="_blank" rel="noopener noreferrer">Help</a>
        </div>
    </div>

    <div class="content-container">
        <fieldset class="group-box input-output-item">
            <legend>Input</legend>
            <textarea class="fill-area" @bind="_input" @bind:event="oninput" spellcheck="false"></textarea>
        </fieldset>

        <fieldset class="group-box input-output-item">
            <legend>Output</legend>
            <textarea class="fill-area" readonly @bind="_output" spellcheck="false"></textarea>
        </fieldset>
    </div>
</div>

@code {
    private const string BlazorDefaultRulePacks = "AlgebraicStrategy, EquationSolving";
    private static readonly Regex RulePacksOptionRegex = new(@"^\s*(?:@option\s+)?RulePacks\s*[:=]", RegexOptions.IgnoreCase | RegexOptions.Multiline);
    private static readonly Regex XmlOptionsBlockRegex = new(@"<Options>(.*?)</Options>", RegexOptions.IgnoreCase | RegexOptions.Singleline);
    private string _input = "";
    private string _output = "";
    private bool _isSolving = false;
    private List<string> _examples = new();
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _examples = await Http.GetFromJsonAsync<List<string>>("examples/examples.json") ?? new();
        }
        catch (Exception ex)
        {
            _output = "Error loading initial data: " + ex.Message;
        }
    }

    private async Task OnExampleSelected(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name)) return;

        try
        {
            _input = await Http.GetStringAsync($"examples/{name}");
        }
        catch (Exception ex)
        {
            _output = "Error loading example: " + ex.Message;
        }
    }

    private async Task StartSolving()
    {
        if (_isSolving || string.IsNullOrWhiteSpace(_input)) return;
        _isSolving = true;
        _output = "Solving...";
        _cts = new CancellationTokenSource();

        try
        {
            await Task.Yield();

            var wrapper = new ProblemScriptEGraphWrapper();
            var effectiveInput = ApplyBlazorDefaultRulePacks(_input);
            _output = await Task.Run(() => wrapper.SolveWithEGraph(effectiveInput, _cts.Token), _cts.Token);
        }
        catch (OperationCanceledException)
        {
            _output = "Solving stopped by user.";
        }
        catch (Exception ex)
        {
            _output = "Error: " + ex.Message;
        }
        finally
        {
            _isSolving = false;
            _cts?.Dispose();
            _cts = null;
        }
    }

    private void StopSolving()
    {
        _cts?.Cancel();
    }

    private static string ApplyBlazorDefaultRulePacks(string script)
    {
        if (string.IsNullOrWhiteSpace(script) || RulePacksOptionRegex.IsMatch(script))
        {
            return script;
        }

        var lineEnding = script.Contains("\r\n", StringComparison.Ordinal) ? "\r\n" : "\n";
        var xmlOptionsMatch = XmlOptionsBlockRegex.Match(script);
        if (xmlOptionsMatch.Success)
        {
            var optionsContent = xmlOptionsMatch.Groups[1].Value;
            var trimmedOptions = optionsContent.TrimEnd();
            var updatedOptions = string.IsNullOrWhiteSpace(trimmedOptions)
                ? $"{lineEnding}  RulePacks: {BlazorDefaultRulePacks}{lineEnding}"
                : $"{lineEnding}{trimmedOptions}{lineEnding}  RulePacks: {BlazorDefaultRulePacks}{lineEnding}";

            return script[..xmlOptionsMatch.Groups[1].Index] +
                   updatedOptions +
                   script[(xmlOptionsMatch.Groups[1].Index + xmlOptionsMatch.Groups[1].Length)..];
        }

        var trimmedScript = script.TrimStart();
        return $"<Options>{lineEnding}  RulePacks: {BlazorDefaultRulePacks}{lineEnding}</Options>{lineEnding}{lineEnding}{trimmedScript}";
    }
}

<style>
    .main-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        width: 100%;
        padding: 1rem;
        box-sizing: border-box;
        overflow: hidden;
        background:
            radial-gradient(circle at top right, rgba(74, 144, 226, 0.18), transparent 28%),
            linear-gradient(180deg, #06111f 0%, #081a31 100%);
        color: #edf5ff;
    }

    .page-header {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .page-kicker {
        margin: 0 0 0.35rem;
        color: #89d1b6;
        font-size: 0.82rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    h1 {
        margin: 0;
        font-family: "Palatino Linotype", "Book Antiqua", Georgia, serif;
        letter-spacing: -0.03em;
    }

    .page-summary {
        max-width: 52rem;
        margin: 0.5rem 0 0;
        color: #c2d3e7;
    }

    .header-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: flex-start;
    }

    .toolbar {
        display: flex;
        flex-direction: row;
        align-items: stretch;
        gap: 0.5rem;
        min-height: 2.5rem;
        padding: 0.25rem 0.5rem;
        margin-bottom: 1rem;
        flex-wrap: wrap;
        box-sizing: border-box;
    }

    .toolbar .group-box, .toolbar fieldset {
        border: none;
        padding: 0;
        margin: 0;
        background: transparent;
        display: flex;
        align-items: center;
    }

    .toolbar .form-select {
        height: 100%;
        box-sizing: border-box;
    }

    .toolbar .btn {
        height: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 0.75rem;
        border-radius: 6px;
    }

    .toolbar-section {
        display: flex;
        gap: 5px;
    }

    .content-container {
        display: flex;
        flex: 1;
        gap: 10px;
        overflow: hidden;
        margin-top: 1rem;
    }

    @@media (min-aspect-ratio: 1/1) {
        .content-container {
            flex-direction: row;
        }
    }

    @@media (max-aspect-ratio: 1/1) {
        .content-container {
            flex-direction: column;
        }
    }

    .group-box {
        border: 1px solid rgba(255, 255, 255, 0.28);
        padding: 5px 10px 10px 10px;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 0;
        background: rgba(255, 255, 255, 0.03);
    }

    .group-box legend {
        float: none;
        width: auto;
        padding: 0 5px;
        margin-bottom: 0;
        font-size: 0.9rem;
        font-weight: bold;
        color: #b8d0f0;
    }

    .examples-group {
        padding: 0 10px 5px 10px;
    }

    .input-output-item {
        flex: 1;
        min-height: 0;
    }

    .fill-area {
        flex: 1;
        width: 100%;
        resize: none;
        font-family: 'Cascadia Code', 'Courier New', Courier, monospace;
        font-size: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: #08111f;
        color: #edf5ff;
        padding: 10px;
        box-sizing: border-box;
        height: 100%;
        min-height: 0;
        border-radius: 8px;
    }
</style>
