@page "/"

<div class="landing-shell">
    <section class="landing-hero">
        <p class="landing-kicker">SymbolicComputation.com</p>
        <h1>Symbolic Computation, AI, And Mathematics</h1>
        <p class="landing-copy">
            Explore Sym Online, read the library, or open the product and services page. The goal of the site is to
            connect rigorous mathematical structure with practical symbolic tooling and modern AI workflows.
        </p>
    </section>

    <section class="landing-grid">
        <article class="landing-card">
            <span class="mini-label">Sym</span>
            <h2>Sym Online</h2>
            <p>
                Run the main browser-based Sym interface for algebraic simplification, calculus queries, equation
                solving, tensor rewrites, and ProblemScript experimentation.
            </p>
            <a class="landing-button primary" href="/sym">Open Sym Online</a>
        </article>

        <article class="landing-card">
            <span class="mini-label">Library</span>
            <h2>Library</h2>
            <p>
                Read connected pages on symbolic computation, expression trees, rewriting systems, e-graphs, AI-assisted
                mathematics, Jacobians, Hessians, tensor contraction, and related topics.
            </p>
            <a class="landing-button secondary" href="/library/">Open Library</a>
        </article>

        <article class="landing-card">
            <span class="mini-label">ProductSection</span>
            <h2>Product And Services</h2>
            <p>
                View the product and services page for custom mathematical software, agentic systems, and related
                engineering work built around symbolic computation and technical software.
            </p>
            <a class="landing-button secondary" href="/resume.html">Open ProductSection</a>
        </article>
    </section>

    <section class="landing-links">
        <a href="/sym/rewrite-demo">Rewrite Demo</a>
        <a href="/sym/tensor-demo">Tensor Demo</a>
        <a href="/sym/derivative-demo">Derivative Demo</a>
        <a href="/SymUIHelp.html" target="_blank" rel="noopener noreferrer">Sym Help</a>
    </section>
</div>

