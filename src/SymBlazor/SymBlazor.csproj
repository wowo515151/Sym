<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
    <BlazorEnableCompression>false</BlazorEnableCompression>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.2" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.2" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SymSolvers\SymSolvers.csproj">
    <AdditionalProperties>EnableCobra=false;EnableCSharpAnalysis=false</AdditionalProperties>
    </ProjectReference>
  </ItemGroup>

  <Target Name="PreparePublishedSymSite" AfterTargets="Publish">
    <PropertyGroup>
      <_PublishedSiteDir>$(PublishDir)wwwroot\</_PublishedSiteDir>
      <_PublishedSymDir>$(_PublishedSiteDir)sym\</_PublishedSymDir>
      <_PublishedIndexHtml>$(_PublishedSiteDir)sym\index.html</_PublishedIndexHtml>
      <_RewriteScript>$(IntermediateOutputPath)ApplyPublishedBaseHref.ps1</_RewriteScript>
    </PropertyGroup>

    <ItemGroup>
      <_RootHelpFiles Include="$(_PublishedSiteDir)SymHelp.txt" />
      <_RootHelpFiles Include="$(_PublishedSiteDir)SymUIHelp.html" />
      <_FrameworkFiles Include="$(_PublishedSiteDir)_framework\**\*" />
      <_SharedProductSection Include="$(MSBuildProjectDirectory)\wwwroot\ProductSection.html" />
      <_StaticWebAppConfig Include="$(MSBuildProjectDirectory)\staticwebapp.config.json" />
    </ItemGroup>

    <WriteLinesToFile
      File="$(_RewriteScript)"
      Overwrite="true"
      Lines="$ErrorActionPreference = 'Stop'&#x0D;&#x0A;$path = '$(_PublishedIndexHtml)'&#x0D;&#x0A;if (-not (Test-Path -LiteralPath $path)) { exit 0 }&#x0D;&#x0A;if ([string]::IsNullOrWhiteSpace('$(PublishBaseHref)')) {&#x0D;&#x0A;  Remove-Item -Force -ErrorAction SilentlyContinue '$(_PublishedSiteDir)index.html.br', '$(_PublishedSiteDir)index.html.gz'&#x0D;&#x0A;  exit 0&#x0D;&#x0A;}&#x0D;&#x0A;$content = Get-Content -Raw -LiteralPath $path&#x0D;&#x0A;$targetBaseHref = '&lt;base href=&quot;$(PublishBaseHref)&quot; /&gt;'&#x0D;&#x0A;if (-not $content.Contains($targetBaseHref)) {&#x0D;&#x0A;  $updated = $content.Replace('&lt;base href=&quot;/&quot; /&gt;', $targetBaseHref)&#x0D;&#x0A;  if ($content -ceq $updated) { throw 'Expected base href marker was not found in published index.html.' }&#x0D;&#x0A;  Set-Content -LiteralPath $path -Value $updated -NoNewline&#x0D;&#x0A;}&#x0D;&#x0A;Remove-Item -Force -ErrorAction SilentlyContinue '$(_PublishedSiteDir)index.html.br', '$(_PublishedSiteDir)index.html.gz'" />

    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(_RewriteScript)&quot;" />
    <Copy
      SourceFiles="@(_FrameworkFiles)"
      DestinationFiles="@(_FrameworkFiles->'$(_PublishedSymDir)_framework\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true" />
    <Copy
      SourceFiles="@(_SharedProductSection)"
      DestinationFolder="$(_PublishedSiteDir)"
      SkipUnchangedFiles="true" />
    <Delete Files="$(_PublishedSiteDir)ProductSection.html.br;$(_PublishedSiteDir)ProductSection.html.gz" />
    <Copy SourceFiles="@(_RootHelpFiles)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(_StaticWebAppConfig)" DestinationFolder="$(_PublishedSiteDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
