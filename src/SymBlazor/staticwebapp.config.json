{
  "routes": [
    {
      "route": "/sym",
      "rewrite": "/sym/index.html"
    },
    {
      "route": "/sym/",
      "rewrite": "/sym/index.html"
    },
    {
      "route": "/sym/derivative-demo",
      "rewrite": "/sym/index.html"
    },
    {
      "route": "/sym/rewrite-demo",
      "rewrite": "/sym/index.html"
    },
    {
      "route": "/sym/tensor-demo",
      "rewrite": "/sym/index.html"
    },
    {
      "route": "/library",
      "rewrite": "/library/index.html"
    },
    {
      "route": "/library/",
      "rewrite": "/library/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/css/*",
      "/_framework/*",
      "/sym/_framework/*",
      "/sym/css/*",
      "/sym/examples/*",
      "/examples/*",
      "/library/*",
      "/*.txt",
      "/*.html",
      "/sym/*.txt",
      "/sym/*.html",
      "/*.png",
      "/sym/*.png",
      "/*.ico",
      "/favicon.ico"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
