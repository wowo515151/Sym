{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/css/*",
      "/_framework/*",
      "/examples/*",
      "/*.txt",
      "/*.html",
      "/*.png",
      "/*.ico",
      "/favicon.ico"
    ]
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
